---
import Base from '../layouts/Base.astro';
---
<Base>
  <section class="section">
    <div class="container">
      <span class="eyebrow">Coming soon</span>
      <h1 class="mt-4">The local guide every parent wishes they had.</h1>
      <p class="lede mt-4" style="max-width: 640px;">
        From library storytimes to weekend festivals — 1,500+ family activities,
        updated daily. The redesigned homepage is being built section by section.
      </p>
      <div class="mt-6" style="display:flex; gap:12px; flex-wrap:wrap;">
        <a href="https://apps.apple.com/app/fampass/id0000000000" class="btn btn--primary" target="_blank" rel="noopener">Get the app</a>
        <a href="/resources/" class="btn btn--ghost">Browse resources</a>
      </div>
    </div>
  </section>
</Base>
