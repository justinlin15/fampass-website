---
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="container site-footer__top">
    <div class="site-footer__brand">
      <a href="/" class="site-footer__logo">
        <img src="/assets/images/logo.png?v=7" alt="FamPass" width="36" height="36" />
        <span>FamPass</span>
      </a>
      <p class="site-footer__tagline">The local guide every parent wishes they had.</p>
      <a href="https://apps.apple.com/app/fampass/id0000000000" class="app-store-badge" target="_blank" rel="noopener">
        <img src="https://developer.apple.com/assets/elements/badges/download-on-the-app-store.svg" alt="Download on the App Store" />
      </a>
    </div>

    <div class="site-footer__cols">
      <div>
        <h5>Product</h5>
        <ul>
          <li><a href="/#features">Features</a></li>
          <li><a href="/#how-it-works">How it works</a></li>
          <li><a href="/#pricing">Pricing</a></li>
          <li><a href="/#faq">FAQ</a></li>
        </ul>
      </div>
      <div>
        <h5>Company</h5>
        <ul>
          <li><a href="/about.html">About</a></li>
          <li><a href="/resources/">Resources</a></li>
          <li><a href="/support.html">Support</a></li>
        </ul>
      </div>
      <div>
        <h5>Legal</h5>
        <ul>
          <li><a href="/privacy-policy.html">Privacy</a></li>
          <li><a href="/terms-of-service.html">Terms</a></li>
        </ul>
      </div>
    </div>
  </div>

  <div class="container site-footer__bottom">
    <span>© {year} FamPass. Made for families.</span>
  </div>
</footer>

<style>
  .site-footer {
    background: #FAF6F1;
    border-top: 1px solid var(--color-line);
    padding-block: 64px 32px;
    color: var(--color-ink-soft);
  }
  .site-footer__top {
    display: grid;
    grid-template-columns: 1.2fr 2fr;
    gap: 56px;
    align-items: start;
  }
  .site-footer__logo {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-serif);
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--color-ink);
  }
  .site-footer__logo img { border-radius: 8px; }
  .site-footer__tagline {
    margin-top: 14px;
    margin-bottom: 22px;
    max-width: 320px;
    font-size: 0.98rem;
  }
  .site-footer__cols {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }
  .site-footer__cols h5 {
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 14px;
    color: var(--color-ink);
    font-weight: 600;
  }
  .site-footer__cols ul { display: flex; flex-direction: column; gap: 10px; }
  .site-footer__cols a {
    color: var(--color-ink-soft);
    font-size: 0.95rem;
    transition: color .15s ease;
  }
  .site-footer__cols a:hover { color: var(--color-accent); }

  .site-footer__bottom {
    margin-top: 48px;
    padding-top: 24px;
    border-top: 1px solid var(--color-line);
    font-size: 0.88rem;
    color: var(--color-ink-muted);
  }

  @media (max-width: 820px) {
    .site-footer__top { grid-template-columns: 1fr; gap: 40px; }
    .site-footer__cols { grid-template-columns: repeat(2, 1fr); gap: 28px; }
  }
</style>
