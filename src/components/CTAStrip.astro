---
interface Props {
  title?: string;
  body?: string;
}
const {
  title = 'Ready to stop hunting for things to do?',
  body = 'Download FamPass and let weekend planning take less than your morning coffee.',
} = Astro.props;
---
<section class="cta-strip">
  <div class="container">
    <div class="cta-strip__inner">
      <div>
        <h3 class="cta-strip__title">{title}</h3>
        <p class="cta-strip__body">{body}</p>
      </div>
      <a href="https://apps.apple.com/app/fampass/id0000000000" class="app-store-badge" target="_blank" rel="noopener">
        <img src="https://developer.apple.com/assets/elements/badges/download-on-the-app-store.svg" alt="Download on the App Store" />
      </a>
    </div>
  </div>
</section>

<style>
  .cta-strip {
    padding-block: clamp(56px, 7vw, 88px);
    background: var(--color-bg-warm);
    border-top: 1px solid var(--color-line);
  }
  .cta-strip__inner {
    background: var(--color-ink);
    color: #fff;
    border-radius: var(--radius-xl);
    padding: clamp(32px, 4vw, 56px) clamp(28px, 4vw, 56px);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
    flex-wrap: wrap;
  }
  .cta-strip__title {
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 2.5vw + .5rem, 2rem);
    font-weight: 600;
    color: #fff;
    letter-spacing: -0.015em;
    margin-bottom: 8px;
    max-width: 540px;
  }
  .cta-strip__body {
    color: rgba(255,255,255,.78);
    max-width: 540px;
  }
  .cta-strip .app-store-badge { flex-shrink: 0; }

  @media (max-width: 720px) {
    .cta-strip__inner { flex-direction: column; align-items: flex-start; }
  }
</style>
