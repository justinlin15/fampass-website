---
const links = [
  { href: '/#features', label: 'Features' },
  { href: '/#how-it-works', label: 'How it works' },
  { href: '/#pricing', label: 'Pricing' },
  { href: '/resources/', label: 'Resources' },
];
---
<header class="site-header" id="site-header">
  <div class="container site-header__inner">
    <a class="site-header__brand" href="/">
      <img src="/assets/images/logo.png?v=7" alt="FamPass" width="34" height="34" />
      <span>FamPass</span>
    </a>

    <nav class="site-header__nav" aria-label="Primary">
      {links.map(l => <a href={l.href}>{l.label}</a>)}
    </nav>

    <div class="site-header__cta">
      <a href="#download" class="btn btn--primary btn--sm">Get the app</a>
    </div>

    <button class="site-header__toggle" aria-label="Open menu" aria-expanded="false" aria-controls="site-header-mobile">
      <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
        <path d="M3 6h16M3 11h16M3 16h16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
      </svg>
    </button>
  </div>

  <div class="site-header__mobile" id="site-header-mobile" hidden>
    <div class="container">
      {links.map(l => <a href={l.href}>{l.label}</a>)}
      <a href="#download" class="btn btn--primary">Get the app</a>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(255,255,255,.85);
    backdrop-filter: saturate(160%) blur(10px);
    -webkit-backdrop-filter: saturate(160%) blur(10px);
    border-bottom: 1px solid var(--color-line);
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    gap: 24px;
    padding-block: 14px;
  }
  .site-header__brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--color-ink);
  }
  .site-header__brand img {
    border-radius: 8px;
  }

  .site-header__nav {
    display: flex;
    gap: 4px;
    margin-left: auto;
  }
  .site-header__nav a {
    padding: 8px 14px;
    border-radius: var(--radius-pill);
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--color-ink-soft);
    transition: background .15s ease, color .15s ease;
  }
  .site-header__nav a:hover {
    color: var(--color-ink);
    background: rgba(26,26,26,.05);
  }

  .site-header__cta { display: inline-flex; }
  .site-header__cta .btn {
    padding: 10px 18px;
    font-size: 0.94rem;
  }

  .site-header__toggle { display: none; color: var(--color-ink); padding: 8px; }

  .site-header__mobile {
    border-top: 1px solid var(--color-line);
    background: var(--color-bg);
  }
  .site-header__mobile .container {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding-block: 12px 18px;
  }
  .site-header__mobile a {
    padding: 12px 14px;
    border-radius: var(--radius-md);
    color: var(--color-ink);
    font-weight: 500;
  }
  .site-header__mobile a.btn {
    margin-top: 8px;
    color: #fff;
  }

  @media (max-width: 820px) {
    .site-header__nav, .site-header__cta { display: none; }
    .site-header__toggle { display: inline-flex; margin-left: auto; }
  }
</style>

<script is:inline>
  (() => {
    const btn = document.querySelector('.site-header__toggle');
    const panel = document.getElementById('site-header-mobile');
    if (!btn || !panel) return;
    btn.addEventListener('click', () => {
      const open = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!open));
      panel.hidden = open;
    });
    panel.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
      btn.setAttribute('aria-expanded', 'false');
      panel.hidden = true;
    }));
  })();
</script>
