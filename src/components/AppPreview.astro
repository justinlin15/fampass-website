---
const events = [
  { emoji: '📚', title: 'Toddler Storytime', venue: 'Irvine Public Library', tag: 'Free', age: 'Ages 0–3', day: 'Tue', time: '10:30 AM' },
  { emoji: '🎨', title: 'Saturday Art Class',     venue: 'Bowers Kidseum',       tag: '$',    age: 'Ages 4–8', day: 'Sat', time: '10:00 AM' },
  { emoji: '⚽', title: 'Lil\' Kickers Soccer',   venue: 'Anaheim Sports Complex', tag: '$',  age: 'Ages 3–6', day: 'Sun', time: '9:00 AM' },
  { emoji: '🎡', title: 'Spring Family Festival', venue: 'Heritage Park',        tag: 'Free', age: 'All ages',  day: 'Sat', time: '11:00 AM' },
  { emoji: '🦕', title: 'Dinosaur Discovery Day', venue: 'Natural History Museum', tag: '$',  age: 'Ages 5–10', day: 'Sun', time: '1:00 PM' },
  { emoji: '🎭', title: 'Puppet Show: Three Bears', venue: 'Bowers Theater',     tag: '$',    age: 'Ages 2–7', day: 'Wed', time: '11:00 AM' },
];
---
<section class="preview section section--ink">
  <div class="container">
    <div class="section__head">
      <span class="eyebrow">A peek inside</span>
      <h2>What's inside the feed.</h2>
      <p>A small sample of the kinds of activities you'll find in the app.</p>
    </div>

    <div class="preview__grid">
      {events.map(e => (
        <article class="event-card">
          <div class="event-card__top">
            <span class="event-card__emoji">{e.emoji}</span>
            <span class="event-card__tag">{e.tag}</span>
          </div>
          <h3 class="event-card__title">{e.title}</h3>
          <p class="event-card__venue">{e.venue}</p>
          <div class="event-card__meta">
            <span>{e.day} · {e.time}</span>
            <span>·</span>
            <span>{e.age}</span>
          </div>
        </article>
      ))}
    </div>

    <div class="preview__cta">
      <p>Plus 1,494 more inside the app — across every category and age range.</p>
      <a href="https://apps.apple.com/app/fampass/id0000000000" class="btn btn--accent" target="_blank" rel="noopener">
        See them all in the app
      </a>
    </div>
  </div>
</section>

<style>
  .preview__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }
  .event-card {
    background: rgba(255,255,255,.06);
    border: 1px solid rgba(255,255,255,.08);
    border-radius: var(--radius-md);
    padding: 22px;
    backdrop-filter: blur(8px);
    transition: background .15s ease, border-color .15s ease, transform .15s ease;
  }
  .event-card:hover {
    background: rgba(255,255,255,.10);
    border-color: rgba(255,255,255,.18);
    transform: translateY(-2px);
  }
  .event-card__top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
  }
  .event-card__emoji {
    width: 44px; height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgba(255,255,255,.10);
    border-radius: 12px;
    font-size: 22px;
  }
  .event-card__tag {
    background: var(--color-accent);
    color: #fff;
    font-size: 0.78rem;
    font-weight: 600;
    padding: 4px 10px;
    border-radius: var(--radius-pill);
  }
  .event-card__title {
    color: #fff;
    font-size: 1.18rem;
    line-height: 1.3;
    margin-bottom: 4px;
  }
  .event-card__venue {
    color: rgba(255,255,255,.7);
    font-size: 0.92rem;
    margin-bottom: 14px;
  }
  .event-card__meta {
    display: flex;
    gap: 8px;
    font-size: 0.85rem;
    color: rgba(255,255,255,.55);
  }

  .preview__cta {
    margin-top: 48px;
    text-align: center;
  }
  .preview__cta p {
    color: rgba(255,255,255,.7);
    margin-bottom: 18px;
  }

  @media (max-width: 880px) {
    .preview__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 540px) {
    .preview__grid { grid-template-columns: 1fr; }
  }
</style>
