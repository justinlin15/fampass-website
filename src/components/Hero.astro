---
const heroImg = 'https://images.unsplash.com/photo-1503454537195-1dcabb73ffb9?w=1400&q=80&auto=format&fit=crop&crop=faces,edges';
---
<section class="hero" id="top">
  <div class="container hero__inner">
    <div class="hero__copy">
      <span class="eyebrow">Made for parents</span>
      <h1 class="hero__title">
        The local guide every parent <em>wishes</em> they had.
      </h1>
      <p class="lede mt-4">
        From library storytimes to weekend festivals — 1,500+ family activities,
        updated daily. Stop hunting for things to do with the kids. Start doing them.
      </p>

      <div class="hero__actions">
        <a href="https://apps.apple.com/app/fampass/id0000000000" class="app-store-badge" target="_blank" rel="noopener" id="download">
          <img src="https://developer.apple.com/assets/elements/badges/download-on-the-app-store.svg" alt="Download on the App Store" />
        </a>
        <a href="#how-it-works" class="btn btn--ghost">See how it works</a>
      </div>

      <ul class="hero__proof">
        <li><strong>1,500+</strong> activities</li>
        <li><strong>30+</strong> trusted sources</li>
        <li><strong>2×</strong> daily updates</li>
        <li><strong>Free</strong> to start</li>
      </ul>
    </div>

    <div class="hero__media">
      <div class="hero__photo">
        <img src={heroImg} alt="Family enjoying a local activity" loading="eager" />
        <div class="hero__chip hero__chip--top">
          <span class="hero__chip-icon" aria-hidden="true">✨</span> 1,500+ family activities · All ages
        </div>
        <div class="hero__chip hero__chip--bottom">
          <span class="emoji">🎨</span>
          <div>
            <strong>Saturday Art Class</strong>
            <span class="muted">10:00 AM · Ages 4–8</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    background: linear-gradient(180deg, var(--color-bg-warm) 0%, #fff 100%);
    padding-block: clamp(56px, 8vw, 96px) clamp(72px, 10vw, 120px);
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute;
    inset: -10% -10% auto auto;
    width: 520px; height: 520px;
    background: radial-gradient(closest-side, rgba(230,74,74,.10), transparent 70%);
    pointer-events: none;
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: clamp(32px, 5vw, 72px);
    align-items: center;
    position: relative;
  }

  .hero__title {
    margin-top: 18px;
    max-width: 560px;
  }
  .hero__title em {
    font-style: italic;
    font-family: var(--font-serif);
    color: var(--color-accent);
  }

  .hero__actions {
    margin-top: 32px;
    display: flex;
    gap: 14px;
    align-items: center;
    flex-wrap: wrap;
  }

  .hero__proof {
    margin-top: 36px;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 14px;
    max-width: 560px;
    padding-top: 24px;
    border-top: 1px solid var(--color-line);
  }
  .hero__proof li {
    font-size: 0.82rem;
    color: var(--color-ink-muted);
    line-height: 1.35;
  }
  .hero__proof strong {
    display: block;
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-ink);
    letter-spacing: -0.02em;
  }

  /* media */
  .hero__media {
    position: relative;
    display: flex;
    justify-content: center;
  }
  .hero__photo {
    position: relative;
    width: 100%;
    max-width: 520px;
    aspect-ratio: 4 / 5;
    border-radius: var(--radius-xl);
    overflow: visible;
  }
  .hero__photo img {
    width: 100%; height: 100%;
    object-fit: cover;
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-lg);
  }
  .hero__chip {
    position: absolute;
    background: #fff;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-md);
    padding: 12px 16px;
    font-size: 0.88rem;
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--color-ink);
  }
  .hero__chip strong { font-weight: 600; display: block; line-height: 1.2; }
  .hero__chip .muted { font-size: 0.78rem; }
  .hero__chip--top {
    top: 28px; left: -22px;
    font-weight: 500;
  }
  .hero__chip-icon {
    font-size: 14px;
    line-height: 1;
  }
  .hero__chip--bottom {
    bottom: 32px; right: -28px;
    padding: 14px 18px;
  }
  .hero__chip--bottom .emoji {
    width: 38px; height: 38px;
    background: var(--color-accent-lo);
    border-radius: 10px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
  }

  @media (max-width: 960px) {
    .hero__inner { grid-template-columns: 1fr; }
    .hero__media { order: -1; }
    .hero__photo { max-width: 380px; aspect-ratio: 1 / 1; }
    .hero__chip--top { left: -10px; }
    .hero__chip--bottom { right: -10px; }
  }
  @media (max-width: 540px) {
    .hero__proof { grid-template-columns: repeat(2, 1fr); }
    .hero__chip--top { left: 8px; top: 16px; font-size: .8rem; }
    .hero__chip--bottom { right: 8px; bottom: 16px; }
  }
</style>
