---
const reviews = [
  {
    quote: 'I used to spend my Friday nights opening browser tabs trying to figure out the weekend. Now I just open FamPass while the kids are eating breakfast and it\'s already done.',
    name: 'Maya R.',
    role: 'Mom of two · Irvine',
    initials: 'MR',
  },
  {
    quote: 'The library storytimes alone are worth it. We had no idea half of these existed and they\'re mostly free. My toddler thinks we\'re always on a magical adventure.',
    name: 'Daniel K.',
    role: 'Dad · Pasadena',
    initials: 'DK',
  },
  {
    quote: 'Best part: it filters out adult-only stuff automatically. I don\'t have to scroll past wine tastings to find the bounce-house party.',
    name: 'Priya S.',
    role: 'Mom of three · Long Beach',
    initials: 'PS',
  },
];
---
<section class="testimonials section section--warm">
  <div class="container">
    <div class="section__head">
      <span class="eyebrow">What parents are saying</span>
      <h2>Loved by parents who used to hate planning weekends.</h2>
    </div>

    <div class="testimonials__grid">
      {reviews.map(r => (
        <figure class="t-card">
          <div class="t-card__stars" aria-label="5 out of 5 stars">
            {[1,2,3,4,5].map(() => (
              <svg viewBox="0 0 20 20" width="14" height="14" fill="currentColor"><path d="M10 1.5l2.6 5.3 5.9.8-4.3 4.1 1 5.8L10 14.8l-5.2 2.7 1-5.8L1.5 7.6l5.9-.8L10 1.5z"/></svg>
            ))}
          </div>
          <blockquote>{r.quote}</blockquote>
          <figcaption class="t-card__author">
            <span class="t-card__avatar" aria-hidden="true">{r.initials}</span>
            <span>
              <strong>{r.name}</strong>
              <span class="muted">{r.role}</span>
            </span>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .testimonials__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .t-card {
    background: #fff;
    border: 1px solid var(--color-line-soft);
    border-radius: var(--radius-lg);
    padding: 32px 28px;
    display: flex;
    flex-direction: column;
    gap: 18px;
    box-shadow: var(--shadow-sm);
    margin: 0;
  }
  .t-card__stars {
    color: var(--color-accent);
    display: flex;
    gap: 2px;
  }
  .t-card blockquote {
    font-family: var(--font-serif);
    font-size: 1.12rem;
    line-height: 1.45;
    color: var(--color-ink);
    letter-spacing: -0.005em;
    margin: 0;
  }
  .t-card__author {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: auto;
    padding-top: 12px;
    border-top: 1px solid var(--color-line-soft);
  }
  .t-card__author strong { display: block; font-weight: 600; color: var(--color-ink); font-size: .96rem; }
  .t-card__author .muted { font-size: 0.84rem; }
  .t-card__avatar {
    width: 40px; height: 40px;
    border-radius: 50%;
    background: var(--color-accent-lo);
    color: var(--color-accent-hi);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
    font-size: .84rem;
    letter-spacing: .04em;
  }

  @media (max-width: 980px) {
    .testimonials__grid { grid-template-columns: 1fr; max-width: 560px; margin-inline: auto; }
  }
</style>
