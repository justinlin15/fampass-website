---
const photo = 'https://images.pexels.com/photos/8208286/pexels-photo-8208286.jpeg?auto=compress&cs=tinysrgb&w=1800';
---
<section class="final-cta">
  <div class="final-cta__photo" style={`background-image: url('${photo}')`}></div>
  <div class="final-cta__overlay"></div>
  <div class="container final-cta__inner">
    <span class="eyebrow" style="color: var(--color-accent);">Your weekend, sorted</span>
    <h2>Stop hunting. Start showing up.</h2>
    <p class="lede">
      Every library storytime, soccer practice, and weekend festival
      already mapped, filtered, and waiting in your pocket.
    </p>
    <div class="final-cta__actions">
      <a href="https://apps.apple.com/app/fampass/id0000000000" class="app-store-badge" target="_blank" rel="noopener">
        <img src="https://developer.apple.com/assets/elements/badges/download-on-the-app-store.svg" alt="Download on the App Store" />
      </a>
      <span class="final-cta__small">Free to start · No ads in Premium · Cancel anytime</span>
    </div>
  </div>
</section>

<style>
  .final-cta {
    position: relative;
    padding-block: clamp(96px, 14vw, 160px);
    color: #fff;
    isolation: isolate;
    overflow: hidden;
  }
  .final-cta__photo {
    position: absolute; inset: 0;
    background-size: cover;
    background-position: center;
    z-index: -2;
  }
  .final-cta__overlay {
    position: absolute; inset: 0;
    background: linear-gradient(180deg, rgba(26,26,26,.75) 0%, rgba(26,26,26,.85) 100%);
    z-index: -1;
  }
  .final-cta__inner {
    text-align: center;
    max-width: 720px;
    margin-inline: auto;
  }
  .final-cta h2 {
    color: #fff;
    margin-top: 14px;
    font-size: clamp(2.2rem, 4vw + .5rem, 3.6rem);
  }
  .final-cta .lede {
    color: rgba(255,255,255,.85);
    margin-top: 18px;
    font-size: 1.18rem;
  }
  .final-cta__actions {
    margin-top: 32px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    align-items: center;
  }
  .final-cta__small {
    font-size: 0.86rem;
    color: rgba(255,255,255,.6);
    letter-spacing: 0.01em;
  }
</style>
