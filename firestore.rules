rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Blog posts: public read, admin-only write
    match /blog_posts/{postId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Feedback: anyone can create, admin-only read/update/delete
    match /feedback/{feedbackId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // TikTok OAuth credentials: SERVER-ONLY (written by the Vercel callback,
    // read by the marketing worker — both via Firebase Admin SDK, which
    // bypasses these rules). We explicitly deny ALL client access so
    // refresh tokens can never leak to any browser session.
    match /tiktok_credentials/{credId} {
      allow read, write: if false;
    }
  }
}
